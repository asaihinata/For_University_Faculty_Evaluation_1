"""フォントファイルのデータを取得するモジュール"""

from pathlib import Path, PosixPath, WindowsPath
from typing import Literal

from matplotlib.font_manager import FontProperties

__all__ = ["Getfont"]

class Getfont:
    def __init__(self, path: Path | WindowsPath | PosixPath | str) -> None: ...
    def __fspath__(self) -> str: ...
    @property
    def properties(self) -> FontProperties: ...
    @property
    def family(self) -> list[str]: ...
    @property
    def name(self) -> str: ...
    @property
    def size(self) -> float: ...
    @property
    def weight(self) -> int | str: ...
    @property
    def style(self) -> Literal["normal", "italic", "oblique"]: ...
